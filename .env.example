# E2B sandbox API key — get from https://e2b.dev/dashboard
E2B_API_KEY=your_e2b_api_key_here

# OpenAI API key passed to the OpenClaw sandbox
OPENAI_API_KEY=your_openai_api_key_here

# Token used to authenticate with the OpenClaw gateway UI
OPENCLAW_APP_TOKEN=my-gateway-token

# ngrok auth token for TCP tunnel (required for local proxy → E2B routing)
# Get from https://dashboard.ngrok.com/get-started/your-authtoken
# Not needed when PROXY_URL is set (e.g. Railway deployment)
NGROK_AUTHTOKEN=your_ngrok_auth_token_here

# --- Optional overrides ---

# Set this to skip ngrok and use a pre-existing proxy URL (e.g. Railway service URL)
# Example: PROXY_URL=http://my-proxy.railway.app:8080
# PROXY_URL=

# URL of the Flask approval UI — override if running UI remotely
# Default: http://localhost:5000
# APPROVAL_UI_URL=http://localhost:5000

# Port for mitmproxy (default: 8080)
# PROXY_PORT=8080

# Port for Flask approval UI (default: 5000)
# UI_PORT=5000

# OpenClaw gateway port inside the E2B sandbox (default: 18789)
# GATEWAY_PORT=18789

# Max seconds to wait for human approval before failing closed (default: 300)
# APPROVAL_TIMEOUT_SECONDS=300
